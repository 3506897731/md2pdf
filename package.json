{
  "name": "morro-md2pdf",
  "version": "0.2.0",
  "description": "Convert Markdown files into polished PDFs with Playwright",
  "license": "MIT",
  "author": "morro",
  "homepage": "https://github.com/3506897731/md2pdf#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/3506897731/md2pdf.git"
  },
  "bugs": {
    "url": "https://github.com/3506897731/md2pdf/issues"
  },
  "keywords": [
    "markdown",
    "pdf",
    "cli",
    "playwright",
    "katex",
    "highlight"
  ],
  "bin": {
    "md2pdf": "dist/cli.js"
  },
  "files": [
    "dist",
    "assets",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "test": "npm run build && node dist/cli.js --help",
    "pack:check": "npm pack --dry-run --cache /tmp/md2pdf-npm-cache",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.44",
    "markdown-it": "^14.1.1",
    "playwright": "^1.59.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  }
}
